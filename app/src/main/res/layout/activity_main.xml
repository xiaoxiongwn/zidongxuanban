
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button android:id="@+id/btnDate" android:text="选择日期"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnMode" android:text="上一休一"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btnBaseDate" android:text="设置起始上班日期"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:id="@+id/txtResult"
        android:text="结果" android:textSize="30sp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
